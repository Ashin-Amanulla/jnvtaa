NODE_ENV=development
PORT=5454
MONGODB_URI=mongodb://127.0.0.1:27017/jnvtaa
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
JWT_RESET_SECRET=change-me-reset
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=3000
RATE_LIMIT_WRITE_MAX=120
RATE_LIMIT_AUTH_MAX=30

# S3 gallery and uploads
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=your-bucket-name
S3_PUBLIC_BASE_URL=https://your-bucket.s3.ap-south-1.amazonaws.com

# Optional: comma-separated folder prefixes and display names (same index)
# S3_FOLDER_PREFIXES=events/,reunion/
# S3_FOLDER_NAMES=Events,Reunion
#find in env

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# Email (SMTP or Resend)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=info@jnvtaa.in
# RESEND_API_KEY=re_xxxxx

# Google OAuth
FRONTEND_URL=https://jnvtaa.in
GOOGLE_OAUTH_CLIENT_ID=1830
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-
GOOGLE_OAUTH_CALLBACK_URL=https://api.jnvtaa.in/api/auth/google/callback

# Redis (API cache + BullMQ newsletter queue)
# Local: redis://127.0.0.1:6379
# Docker Compose / CI deploy: redis://redis:6379 or redis://jnvtaa-redis:6379
REDIS_URL=redis://redis:6379 

# Seed super admin (used by npm run seed)
SUPER_ADMIN_EMAIL=superadmin@jnvtaa.org
SUPER_ADMIN_PASSWORD=superadmin123
