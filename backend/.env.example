NODE_ENV=development
PORT=5454
MONGODB_URI=mongodb://127.0.0.1:27017/jnvtaa
CORS_ORIGIN=http://localhost:5173

JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Optional: base URL for the deployed S3 gallery JSON (no trailing slash).
# Defaults to https://jnvtaa.in/api/api if unset.
GALLERY_S3_API_BASE=https://jnvtaa.in/api/api
